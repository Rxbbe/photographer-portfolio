PORT=3000

# Optie 1 – plain text (server hasht dit automatisch bij opstarten)
# ADMIN_PASSWORD=MijnWachtwoord123

# Optie 2 – pre-computed bcrypt hash (veiliger, gebruik dit op een server)
# Genereer met: node -e "console.log(require('bcryptjs').hashSync('JouwWachtwoord', 12))"
ADMIN_PASSWORD_HASH=$2a$12$vervang_dit_met_jouw_eigen_hash

JWT_SECRET=verander_dit_naar_een_lang_willekeurig_geheim
